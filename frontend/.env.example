# Base URL for the Flowcast FastAPI backend.
#
# In local development, you can leave this UNSET. Vite's dev server proxies
# /stations and /predict to http://127.0.0.1:9000 (see vite.config.ts) so the
# browser stays on the same origin and avoids CORS entirely.
#
# In production, point this at the host serving the FastAPI backend, e.g.
#   VITE_API_URL=https://api.flowcast.example.com
# VITE_API_URL=http://127.0.0.1:9000
